# Database
# Prisma uses "file:" prefix; adjust the path relative to prisma/schema.prisma
DATABASE_URL="file:../cartrack.db"

# FastAPI scraper service
SCRAPER_PORT=8001

# Next.js public variable — used by the dashboard to talk to the scraper API
NEXT_PUBLIC_SCRAPER_URL=http://localhost:8001

# Email alerts (optional — leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
ALERT_EMAIL=your@email.com

# Default settings applied on first run
DEFAULT_POSTCODE=BS7 8NE
DEFAULT_RADIUS=100
